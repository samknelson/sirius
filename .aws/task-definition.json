{
  "family": "sirius",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/<ECS_TASK_EXECUTION_ROLE>",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/<ECS_TASK_ROLE>",
  "containerDefinitions": [
    {
      "name": "sirius",
      "image": "<IMAGE_PLACEHOLDER_REPLACED_BY_CI>",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "5000" },
        { "name": "AUTH_PROVIDER", "value": "saml" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:sirius/DATABASE_URL" },
        { "name": "SESSION_SECRET", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:sirius/SESSION_SECRET" },
        { "name": "SAML_ENTRY_POINT", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:sirius/SAML_ENTRY_POINT" },
        { "name": "SAML_ISSUER", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:sirius/SAML_ISSUER" },
        { "name": "SAML_CERT", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:sirius/SAML_CERT" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sirius",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "sirius",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:'+(process.env.PORT||5000)+'/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 60
      }
    }
  ]
}
