{
  "$schema": "https://app.flightcontrol.dev/schema.json",
  "ci": {
    "type": "ec2",
    "instanceSize": "t3.large"
  },
  "environments": [
    {
      "id": "production",
      "name": "Production (HTA)",
      "region": "us-east-1",
      "source": {
        "branch": "prod-hta"
      },
      "services": [
        {
          "id": "sirius-app",
          "name": "Sirius Application (HTA)",
          "type": "fargate",
          "buildType": "nixpacks",
          "cpu": 0.5,
          "memory": 1,
          "minInstances": 1,
          "maxInstances": 3,
          "port": 3000,
          "healthCheckPath": "/api/health",
          "envVariables": {
            "NODE_ENV": "production",
            "PORT": "3000"
          }
        }
      ]
    },
    {
      "id": "prod-btu",
      "name": "Production (BTU)",
      "region": "us-east-1",
      "source": {
        "branch": "prod-btu"
      },
      "services": [
        {
          "id": "sirius-app-btu",
          "name": "Sirius Application (BTU)",
          "type": "fargate",
          "buildType": "nixpacks",
          "cpu": 0.5,
          "memory": 1,
          "minInstances": 1,
          "maxInstances": 3,
          "port": 3000,
          "healthCheckPath": "/api/health",
          "envVariables": {
            "NODE_ENV": "production",
            "PORT": "3000"
          }
        }
      ]
    },
    {
      "id": "preview",
      "name": "PR Preview",
      "region": "us-east-1",
      "source": {
        "pr": true,
        "branch": "main"
      },
      "services": [
        {
          "id": "sirius-app-preview",
          "name": "Sirius Application (Preview)",
          "type": "fargate",
          "buildType": "nixpacks",
          "buildCommand": "npm run build",
          "startCommand": "npm run start:preview",
          "cpu": 0.25,
          "memory": 0.5,
          "minInstances": 1,
          "maxInstances": 1,
          "port": 3000,
          "healthCheckPath": "/api/health",
          "envVariables": {
            "NODE_ENV": "production",
            "MOCK_AUTH": "true",
            "PORT": "3000"
          }
        }
      ]
    }
  ]
}
